{
  "expo": {
    "name": "Step 1",
    "slug": "step-1-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "step1",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1216"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.step1.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to capture your daily progress photos.",
        "NSPhotoLibraryUsageDescription": "Used to attach progress photos to your habit logs."
      }
    },
    "android": {
      "package": "com.step1.app",
      "adaptiveIcon": {
        "backgroundColor": "#1a1216",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ff6b1a",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
